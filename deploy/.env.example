# deploy/.env  — 本番の秘密情報。**絶対にコミットしない**（.gitignore 済み）
# cp .env.example .env して埋めること。

# ── 公開ホスト ───────────────────────────────────────────────
# QRコードが指すURL。管理画面(admin.*)ではなく必ず公開ホストにする。
PUBLIC_ORIGIN=https://mikawa-unso.jp

# ── PostgreSQL（NAS 内。外には一切公開されない） ─────────────
POSTGRES_USER=mikawa
POSTGRES_PASSWORD=__ここを長いランダム文字列に__
POSTGRES_DB=mikawa

# アプリが使う接続先。
#   NAS の Postgres を使う場合（通常）:
DATABASE_URL=postgresql://mikawa:__上と同じパスワード__@db:5432/mikawa
#   Neon に戻す（ロールバック）場合はこの行を差し替えるだけ:
# DATABASE_URL=postgresql://neondb_owner:...@ep-....aws.neon.tech/neondb?sslmode=require

# ── セッション ───────────────────────────────────────────────
# 変更するとログイン中の全セッションが無効になる。
# 生成例: openssl rand -hex 32
SESSION_SECRET=__64文字程度のランダム文字列__

# ── Web Push（VAPID） ───────────────────────────────────────
# 既存の購読を活かすため、今使っている鍵をそのまま入れること。
# 鍵を変えると既存のプッシュ購読は全て無効になり、ドライバー全員が再購読するまで通知が届かない。
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@mikawa-unso.jp

# ── Cloudflare Tunnel ───────────────────────────────────────
# Zero Trust ダッシュボード → Networks → Tunnels でトンネルを作ると発行されるトークン。
TUNNEL_TOKEN=

# ── バックアップ保持日数 ────────────────────────────────────
BACKUP_RETENTION_DAYS=60
